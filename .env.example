# deeprun Environment Configuration
# Copy this file to .env and configure your values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (REQUIRED)
# PostgreSQL connection string
DATABASE_URL=postgresql://deeprun:deeprun@localhost:5432/deeprun

# Security (REQUIRED)
# Generate with: openssl rand -hex 32
AUTH_TOKEN_SECRET=your_auth_token_secret_here_minimum_32_characters_required

# CORS (REQUIRED)
# Comma-separated list of allowed origins (no wildcards)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# AI PROVIDERS (At least one required for generation)
# =============================================================================

# OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Default provider (openai, anthropic, or mock)
# DEEPRUN_DEFAULT_PROVIDER=openai

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Cookie Security
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# COOKIE_DOMAIN=.yourdomain.com

# Trust Proxy (for load balancers)
TRUST_PROXY=false

# Rate Limiting
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_LOGIN_WINDOW_SEC=600
RATE_LIMIT_GENERATION_MAX=30
RATE_LIMIT_GENERATION_WINDOW_SEC=300

# Metrics
METRICS_ENABLED=true
# METRICS_AUTH_TOKEN=your_metrics_token_here

# Agent Configuration
AGENT_FS_MAX_FILES_PER_STEP=50
AGENT_FS_MAX_TOTAL_DIFF_BYTES=1048576
AGENT_FS_MAX_FILE_BYTES=1572864
AGENT_LIGHT_VALIDATION_MODE=warn
AGENT_HEAVY_VALIDATION_MODE=warn
AGENT_CORRECTION_POLICY_MODE=warn

# V1 Readiness Validation
V1_DOCKER_BIN=docker
V1_DOCKER_BUILD_TIMEOUT_MS=300000
V1_DOCKER_BOOT_TIMEOUT_MS=60000

# Deployment Configuration
DEPLOY_DOCKER_BIN=docker
# DEPLOY_REGISTRY=ghcr.io/yourorg
DEPLOY_BASE_DOMAIN=deeprun.app
# DEPLOY_PUBLIC_URL_TEMPLATE=https://{{subdomain}}.{{baseDomain}}
# DEPLOY_DOCKER_NETWORK=deeprun-network
DEPLOY_CONTAINER_PORT=3000
DEPLOY_STOP_PREVIOUS=true

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Test Database (for running tests)
# TEST_DATABASE_URL=postgresql://deeprun:deeprun@localhost:5432/deeprun_test

# Debug Logging
# DEBUG=deeprun:*